# ===== 环境变量 — 不进镜像，通过 docker run -e 注入 =====
.env
.env.*
!.env.example

# ===== 依赖 — 在镜像内重新安装 =====
node_modules/

# ===== 构建产物 — 在镜像内重新编译 =====
dist/
*.tsbuildinfo

# ===== Git — 不需要 =====
.git/
.gitignore
.gitattributes

# ===== 文档 — 非运行时依赖 =====
docs/

# ===== CI/CD — 不进镜像 =====
.github/
.husky/

# ===== IDE — 不进镜像 =====
.vscode/
.idea/
*.swp
*.swo

# ===== Claude Code — 不进镜像 =====
.claude/

# ===== Trae IDE spec — 不进镜像 =====
.trae/

# ===== 开发计划（中文目录） — 不进镜像 =====
开发计划/

# ===== Playwright 测试产物（E2E） — 不进镜像 =====
playwright-report/
test-results/

# ===== 测试 — 不进镜像 =====
test/
tests/
*.spec.ts
*.test.ts
coverage/

# ===== 杂项 =====
.DS_Store
*.md
!apps/**/README.md
LICENSE
CHANGELOG*
docker-compose*.yml
Dockerfile*
.dockerignore

# ===== 双星通配（覆盖 apps/*/dist、packages/*/dist 等所有子目录） =====
**/node_modules
**/dist
apps/*/dist
**/*.map
**/__tests__
**/coverage
**/*.log
**/logs
**/.cache
**/.tmp
**/.turbo
**/.vite
**/.next
**/.nuxt
Thumbs.db

# ===== Prisma migrations =====
# 说明：prisma generate 需要 schema.prisma，保留；
# migrations 目录在生产用 prisma migrate deploy 跑，build 阶段不复制进去（节省体积）
prisma/migrations

