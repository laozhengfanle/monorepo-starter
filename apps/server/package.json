{
    "name": "@apps/server",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "type": "module",
    "license": "UNLICENSED",
    "scripts": {
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "prebuild": "rm -rf dist",
        "build": "pnpm exec prisma generate && nest build && node scripts/compile-prisma-client.mjs",
        "format": "prettier --write \"src/**/*.ts\"",
        "start": "node dist/main",
        "start:dev": "node --import ./scripts/swc-register.mjs src/main.ts",
        "start:debug": "node --import ./scripts/swc-register.mjs --inspect src/main.ts",
        "start:prod": "NODE_ENV=${NODE_ENV:-production} node dist/main",
        "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:cov": "vitest run --coverage",
        "test:debug": "vitest --inspect-brk --no-file-parallelism",
        "generate:schema": "tsx scripts/generate-schema-artifact.ts",
        "schema:check": "tsx scripts/check-schema-artifact.ts",
        "migration:check": "node -e \"const fs=require('fs');const path=require('path');const lockFile=path.join('prisma','migrations','migration_lock.toml');if(!fs.existsSync(lockFile)){console.error('❌ '+lockFile+' 缺失');process.exit(1)}const content=fs.readFileSync(lockFile,'utf8');if(!/provider\\s*=\\s*\\\"postgresql\\\"/.test(content)){console.error('❌ migration_lock.toml provider 字段不是 postgresql（必须为 postgresql 与 prisma schema 一致）');process.exit(1)}const migrationsDir=path.join('prisma','migrations');const dirs=fs.readdirSync(migrationsDir,{withFileTypes:true}).filter(d=>d.isDirectory()).map(d=>d.name).sort();console.log('✅ migration_lock.toml 验证通过（provider=postgresql）');console.log('✅ 当前已存在 '+dirs.length+' 个迁移：');dirs.forEach(d=>console.log('   - '+d))\"",
        "db:migrate": "prisma migrate deploy",
        "db:migrate:status": "prisma migrate status",
        "db:migrate:create": "prisma migrate dev --create-only",
        "db:migrate:reset": "prisma migrate reset --force",
        "db:generate": "prisma generate",
        "db:seed": "prisma db seed",
        "db:studio": "prisma studio"
    },
    "dependencies": {
        "@alicloud/dysmsapi20170525": "^4.5.1",
        "@apollo/server": "^5.5.1",
        "@as-integrations/express5": "^1.1.2",
        "@nestjs/apollo": "^13.4.2",
        "@nestjs/common": "^11.1.24",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.1.24",
        "@nestjs/graphql": "^13.4.2",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.1.24",
        "@nestjs/schedule": "^6.1.3",
        "@nestjs/terminus": "^11.1.1",
        "@nestjs/throttler": "^6.5.0",
        "@packages/shared": "workspace:*",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@willsoto/nestjs-prometheus": "^6.1.0",
        "bcrypt": "^6.0.0",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "dataloader": "^2.2.3",
        "express": "^5.2.1",
        "graphql": "^16.14.0",
        "graphql-depth-limit": "^1.1.0",
        "graphql-type-json": "^0.3.2",
        "helmet": "^8.2.0",
        "ioredis": "^5.11.0",
        "jose": "^6.2.3",
        "nestjs-pino": "^4.6.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.21.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "prisma": "^7.8.0",
        "prom-client": "^15.1.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "uuidv7": "^1.2.1",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@mermaid-js/mermaid-cli": "^11.15.0",
        "@nestjs/cli": "^11.0.21",
        "@nestjs/schematics": "^11.1.0",
        "@nestjs/testing": "^11.1.24",
        "@swc-node/register": "^1.11.1",
        "@swc/cli": "^0.8.1",
        "@swc/core": "^1.15.41",
        "@types/bcrypt": "^5.0.2",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.6",
        "@types/node": "^25.9.1",
        "@types/passport-jwt": "^4.0.1",
        "@types/pg": "^8.20.0",
        "@types/pino-http": "^6.1.0",
        "@types/supertest": "^7.2.0",
        "dotenv": "^17.4.2",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "prisma-erd-generator": "^2.4.3",
        "supertest": "^7.2.2",
        "tsc-alias": "^1.8.17",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.20.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vitest": "^4.1.7"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    }
}
