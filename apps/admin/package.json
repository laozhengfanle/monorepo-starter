{
    "name": "@apps/admin",
    "private": true,
    "version": "1.0.1",
    "type": "module",
    "scripts": {
        "dev": "lsof -ti:5173 | xargs kill -9 2>/dev/null; vite",
        "typecheck": "vue-tsc -b",
        "build": "vue-tsc -b && vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint . --fix",
        "format": "prettier --write .",
        "preinstall": "node -e \"if (!process.env.npm_execpath?.includes('pnpm')) { console.error('\\x1b[31m请使用 pnpm: pnpm install\\x1b[0m'); process.exit(1); }\"",
        "bundle:analyze": "BUNDLE_ANALYZE=true vue-tsc -b && BUNDLE_ANALYZE=true vite build"
    },
    "packageManager": "pnpm@11.4.0",
    "dependencies": {
        "@ant-design/icons-vue": "^7.0.1",
        "@packages/shared": "workspace:*",
        "@vicons/antd": "^0.13.0",
        "@vicons/carbon": "^0.13.0",
        "@vicons/fa": "^0.13.0",
        "@vicons/fluent": "^0.13.0",
        "@vicons/ionicons4": "^0.13.0",
        "@vicons/ionicons5": "^0.13.0",
        "@vicons/material": "^0.13.0",
        "@vicons/tabler": "^0.13.0",
        "@vueuse/core": "^14.0.0",
        "@vueuse/motion": "^3.0.3",
        "dompurify": "^3.4.10",
        "echarts": "^6.1.0",
        "highlight.js": "^11.11.1",
        "marked": "^18.0.5",
        "marked-highlight": "^2.2.4",
        "mitt": "^3.0.1",
        "naive-ui": "^2.44.1",
        "pinia": "^3.0.4",
        "pinia-plugin-persistedstate": "^4.7.1",
        "vue": "^3.5.34",
        "vue-echarts": "^8.0.1",
        "vue-router": "^5.1.0"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@pinia/testing": "^1.0.3",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^24.12.3",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.8.0",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.9.1",
        "eslint": "^10.4.1",
        "eslint-plugin-vue": "^10.9.2",
        "happy-dom": "^20.0.5",
        "prettier": "^3.8.3",
        "rollup-plugin-visualizer": "^7.0.1",
        "tailwindcss": "^4.3.0",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.60.1",
        "unplugin-auto-import": "^21.0.0",
        "unplugin-vue-components": "^32.1.0",
        "vite": "^8.0.16",
        "vite-plugin-bundlesize": "^0.3.0",
        "vitest": "^4.1.7",
        "vue-tsc": "^3.2.8"
    }
}
