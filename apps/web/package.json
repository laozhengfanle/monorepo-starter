{
    "name": "@apps/web",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "typecheck": "vue-tsc -b",
        "build": "vue-tsc -b && vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint \"src/**/*.{ts,vue}\" --fix",
        "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
        "bundle:analyze": "BUNDLE_ANALYZE=true vue-tsc -b && BUNDLE_ANALYZE=true vite build"
    },
    "dependencies": {
        "@packages/shared": "workspace:*",
        "graphql-request": "^7.1.2",
        "naive-ui": "^2.40.1",
        "pinia": "^2.2.4",
        "pinia-plugin-persistedstate": "^4.7.1",
        "vue": "^3.5.34",
        "vue-router": "^4.4.5"
    },
    "devDependencies": {
        "@packages/config": "workspace:*",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^24.12.3",
        "@vicons/ionicons5": "^0.13.0",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.9.1",
        "@vueuse/core": "^11.2.0",
        "eslint": "^10.4.0",
        "happy-dom": "^15.11.0",
        "prettier": "^3.8.3",
        "rollup-plugin-visualizer": "^7.0.1",
        "tailwindcss": "^4.3.0",
        "typescript": "~6.0.2",
        "unplugin-auto-import": "^0.18.3",
        "unplugin-vue-components": "^0.27.4",
        "vite": "^8.0.16",
        "vite-plugin-bundlesize": "^0.3.0",
        "vitest": "^4.1.7",
        "vue-tsc": "^3.2.8"
    }
}
